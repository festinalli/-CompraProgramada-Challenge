# Copie para `.env` (que é gitignored) e ajuste os valores.
# docker compose lê este arquivo automaticamente quando executado a partir de docker/.

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root
DB_PASSWORD=change-me-corretora

# JWT — use um segredo aleatório com no mínimo 32 caracteres
JWT_SECRET_KEY=change-me-please-use-a-random-secret-with-32+chars

# Admin (usuário de backoffice provisionado no 1º boot).
# SEM credencial default: defina aqui. Senha com no mínimo 12 caracteres.
# Se não definir, NENHUM admin é criado (login-admin ficará indisponível até provisionar).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte-12+
